# Veritabanı — DATABASE_URL veya ayrı alanlar (ikisinden biri yeterli)
# DATABASE_URL=postgresql://user:pass@localhost:5433/gamepm_db
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=gamepm_db
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNC=true

NODE_ENV=development
PORT=3000

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173

THROTTLE_TTL=60
THROTTLE_LIMIT=10

GEMINI_API_KEY=
